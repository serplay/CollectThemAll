node_modules
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Output directory used by Vite / Svelte
dist/
dist-isolation/

# Rust/Tauri compilation artifacts
src-tauri/target/

# Android build artifacts generated by Gradle / tauri android build.
# The Gradle project, manifest, and resources ARE tracked; only derived
# output, local SDK paths, and signing material are excluded.
src-tauri/gen/android/.gradle/
src-tauri/gen/android/build/
src-tauri/gen/android/app/build/
src-tauri/gen/android/local.properties
src-tauri/gen/android/.idea/
# Keystore + signing config must never be committed — store base64+passwords
# in encrypted Actions secrets instead (see release workflow).
*.keystore
*.jks
key.properties

# iOS build artifacts generated by Xcode / CocoaPods / tauri ios build.
# The Xcode project, asset catalogs, and entitlement plists ARE tracked
# (they carry signing config); only derived/downloaded/user-local junk is excluded.
src-tauri/gen/apple/build/
src-tauri/gen/apple/Pods/
src-tauri/gen/apple/*.xcuserstate
src-tauri/gen/apple/Externals/
DerivedData/

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local environment files
.env
.env.local
.env.*.local