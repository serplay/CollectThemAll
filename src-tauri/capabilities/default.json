{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities shared across all platforms — fs access the map and asset pipeline need",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/assets/**" }]
    },
    "fs:allow-exists",
    "fs:allow-read-text-file"
  ]
}
