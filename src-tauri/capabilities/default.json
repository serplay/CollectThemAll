{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main app windows",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/assets/**" }]
    },
    "fs:allow-exists"
  ]
}