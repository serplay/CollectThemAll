{
  "productName": "cta-collectthemall",
  "version": "0.1.0",
  "identifier": "com.cta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CTA - Manager",
        "label": "main",
        "width": 1000,
        "height": 700
      },
      {
        "title": "CTA - Overlay",
        "label": "overlay",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; img-src 'self' asset: https://asset.localhost https://cdn.mapgenie.io;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}