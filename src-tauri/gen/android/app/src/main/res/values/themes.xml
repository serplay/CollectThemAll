<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.cta_collectthemall" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Transparent status bar so the app's dark background (#010201) bleeds through
             rather than showing a coloured bar above the WebView. Combined with
             viewport-fit=cover and env(safe-area-inset-top) in the frontend this gives
             a full-bleed layout without content hiding under the status icons. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>
